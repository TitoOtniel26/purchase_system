<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Purchase Management System</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <nav class="navbar">
        <div class="container">
            <div class="nav-brand">
                <h1><i class="fas fa-store"></i> Purchase System</h1>
            </div>
            <div class="nav-links">
                <a href="/" class="<%= currentPage === 'dashboard' ? 'active' : '' %>">
                    <i class="fas fa-chart-pie"></i> Dashboard
                </a>
                <a href="/products" class="<%= currentPage === 'products' ? 'active' : '' %>">
                    <i class="fas fa-box"></i> Products
                </a>
                <a href="/purchases" class="<%= currentPage === 'purchases' ? 'active' : '' %>">
                    <i class="fas fa-shopping-cart"></i> Purchases
                </a>
                <a href="/purchases/new" class="btn btn-primary btn-nav">
                    <i class="fas fa-plus"></i> New Purchase
                </a>
            </div>
        </div>
    </nav>

    <main>
        <div class="container">
            <%- body %>
        </div>
    </main>

    <footer class="footer">
        <div class="container">
            <p>&copy; 2026 Purchase Management System. All rights reserved.</p>
        </div>
    </footer>

    <script src="/js/main.js"></script>
</body>
</html>