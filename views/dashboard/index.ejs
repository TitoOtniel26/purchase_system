<%
  const currentPage = 'dashboard';
%>
<!DOCTYPE html>
<html>
<head>
  <%- include('../partials/head') %>
</head>
<body>
  <%- include('../partials/navbar', { currentPage }) %>
  
  <div class="container">
    <h2><i class="fas fa-chart-pie"></i> Dashboard Overview</h2>
    
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-icon"><i class="fas fa-box"></i></div>
        <h3>Total Products</h3>
        <p class="stat-number"><%= stats.totalProducts || 0 %></p>
      </div>
      <div class="stat-card">
        <div class="stat-icon"><i class="fas fa-shopping-cart"></i></div>
        <h3>Total Purchases</h3>
        <p class="stat-number"><%= stats.totalPurchases || 0 %></p>
      </div>
      <div class="stat-card">
        <div class="stat-icon"><i class="fas fa-warehouse"></i></div>
        <h3>Total Stock</h3>
        <p class="stat-number"><%= stats.totalStock || 0 %></p>
      </div>
    </div>

    <div class="card">
      <div class="card-header">
        <h3><i class="fas fa-clock"></i> Recent Purchases</h3>
        <a href="/purchases" class="btn btn-secondary btn-sm">View All</a>
      </div>
      <div class="card-body">
        <table class="table">
          <thead>
            <tr>
              <th>Product</th>
              <th>Qty</th>
              <th>Total</th>
              <th>Admin</th>
              <th>Status</th>
              <th>Date</th>
            </tr>
          </thead>
          <tbody>
            <% if (recentPurchases && recentPurchases.length > 0) { %>
              <% recentPurchases.forEach(purchase => { %>
                <tr>
                  <td><strong><%= purchase.product_name %></strong></td>
                  <td><%= purchase.quantity %></td>
                  <td>Rp <%= purchase.total_price.toLocaleString() %></td>
                  <td><%= purchase.admin_name || '-' %></td>
                  <td>
                    <span class="status status-<%= purchase.status %>">
                      <%= purchase.status %>
                    </span>
                  </td>
                  <td><%= new Date(purchase.purchase_date).toLocaleDateString('id-ID') %></td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="6" class="text-center">No purchases yet</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <%- include('../partials/footer') %>
</body>
</html>