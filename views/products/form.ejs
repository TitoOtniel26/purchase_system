<%
  const currentPage = 'products';
%>
<!DOCTYPE html>
<html>
<head>
  <%- include('../partials/head') %>
</head>
<body>
  <%- include('../partials/navbar', { currentPage }) %>
  
  <div class="container">
    <div class="form-container">
      <h2><i class="fas fa-<%= product ? 'edit' : 'plus-circle' %>"></i> <%= product ? 'Edit' : 'Add' %> Product</h2>
      <p class="form-subtitle"><%= product ? 'Update product information' : 'Create a new product' %></p>

      <% if (error) { %>
        <div class="alert alert-danger">
          <i class="fas fa-exclamation-circle"></i> <%= error %>
        </div>
      <% } %>

      <form action="<%= product ? '/products/update/' + product.id : '/products' %>" method="POST" class="purchase-form">
        <div class="form-group">
          <label for="name">Product Name <span class="required">*</span></label>
          <input type="text" 
                 name="name" 
                 id="name" 
                 required 
                 placeholder="Enter product name"
                 value="<%= product ? product.name : '' %>">
        </div>

        <div class="form-group">
          <label for="price">Price <span class="required">*</span></label>
          <input type="number" 
                 name="price" 
                 id="price" 
                 min="0" 
                 step="0.01" 
                 required 
                 placeholder="Enter price"
                 value="<%= product ? product.price : '' %>">
        </div>

        <div class="form-group">
          <label for="category">Category</label>
          <input type="text" 
                 name="category" 
                 id="category" 
                 placeholder="Enter category"
                 value="<%= product ? product.category : '' %>">
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary">
            <i class="fas fa-save"></i> <%= product ? 'Update' : 'Create' %> Product
          </button>
          <a href="/products" class="btn btn-secondary">
            <i class="fas fa-times"></i> Cancel
          </a>
        </div>
      </form>
    </div>
  </div>

  <%- include('../partials/footer') %>
</body>
</html>