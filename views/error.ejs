<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <nav class="navbar">
    <div class="container">
      <div class="nav-brand">
        <h1><i class="fas fa-store"></i> Purchase System</h1>
      </div>
      <div class="nav-links">
        <a href="/">Dashboard</a>
        <a href="/products">Products</a>
        <a href="/purchases">Purchases</a>
      </div>
    </div>
  </nav>

  <div class="container">
    <div style="text-align: center; padding: 4rem 2rem;">
      <div style="font-size: 5rem; color: #dc3545; margin-bottom: 2rem;">
        <i class="fas fa-exclamation-circle"></i>
      </div>
      <h1 style="font-size: 3rem; margin-bottom: 1rem;"><%= statusCode || 500 %></h1>
      <h2 style="color: #666; margin-bottom: 2rem;"><%= title || 'Error' %></h2>
      <p style="color: #888; margin-bottom: 2rem; max-width: 500px; margin-left: auto; margin-right: auto;">
        <%= message || 'An unexpected error occurred. Please try again later.' %>
      </p>
      <div style="display: flex; gap: 1rem; justify-content: center;">
        <a href="/" class="btn btn-primary">
          <i class="fas fa-home"></i> Go to Dashboard
        </a>
        <a href="javascript:history.back()" class="btn btn-secondary">
          <i class="fas fa-arrow-left"></i> Go Back
        </a>
      </div>
    </div>
  </div>

  <%- include('partials/footer') %>
</body>
</html>